---
   import Footer from '../components/Footer.astro';
import '../styles/global.css';
 import { ViewTransitions } from 'astro:transitions'; 
   import terminalCommands from '../data/terminal-commands.json';
      import ThemeSwitcher from '../components/ThemeSwitcher.astro';
	  import KonamiEgg from '../components/KonamiEgg.astro';
   
   
   const commandsJSON = JSON.stringify(terminalCommands);

interface Props {
  title: string;
  description?: string;
  lang?: string;
  dir?: 'ltr' | 'rtl';
}

const { 
  title, 
  description = 'Portfolio of Zeeshan Haider - Cybersecurity & Research Support Engineer', 
  lang = 'en', 
  dir = 'ltr' 
} = Astro.props;
---

<!DOCTYPE html>
<html lang={lang} dir={dir} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
	<ViewTransitions />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>
	{title}</title>
	
  </head>
  <body class="bg-bg text-text font-sans antialiased">
    <slot />
	<!-- Global Scroll Reveal Animation Engine -->
<style is:global>
  .reveal {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.8s ease-out, transform 0.8s ease-out;
  }
  .reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }
    /* ========================================== */
  /* PREMIUM PAGE TRANSITIONS                   */
  /* ========================================== */
  @keyframes page-enter {
    from { opacity: 0; transform: translateY(15px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes page-exit {
    from { opacity: 1; transform: translateY(0); }
    to { opacity: 0; transform: translateY(-10px); }
  }

  /* Apply to the whole page root */
  ::view-transition-old(root) {
    animation: 0.2s ease-out both page-exit;
  }
  ::view-transition-new(root) {
    animation: 0.4s cubic-bezier(0.16, 1, 0.3, 1) both page-enter;
  }
</style>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1 });

  // Wait for the DOM to load
  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
  });
  
  // Also run on Astro page loads (for client-side routing)
  document.addEventListener('astro:page-load', () => {
    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
  });
</script>

<!-- ========================================== -->
<!-- CYBER TERMINAL EASTER EGG (Ctrl+K or ~)    -->
<!-- ========================================== -->
<div id="cyber-terminal" class="hidden fixed inset-0 z-[100] bg-black/80 backdrop-blur-sm flex items-center justify-center p-4 animate-fade-in">
  <div class="w-full max-w-3xl h-[70vh] bg-[#0d1117] border border-green-500/30 rounded-xl shadow-2xl shadow-green-500/10 flex flex-col font-mono text-green-400 overflow-hidden ring-1 ring-white/5">
    
    <!-- Terminal Header (macOS style) -->
    <div class="flex items-center justify-between px-4 py-3 bg-[#161b22] border-b border-green-500/20">
      <div class="flex gap-2">
        <span class="w-3 h-3 rounded-full bg-red-500/80"></span>
        <span class="w-3 h-3 rounded-full bg-yellow-500/80"></span>
        <span class="w-3 h-3 rounded-full bg-green-500/80"></span>
      </div>
      <span class="text-xs text-gray-400 tracking-wider">zxsprd@secure-shell:~</span>
      <button id="close-terminal" class="text-gray-400 hover:text-white transition-colors text-lg leading-none">✕</button>
    </div>

    <!-- Terminal Output Area -->
    <div id="terminal-output" class="flex-1 p-5 overflow-y-auto text-sm leading-relaxed custom-scrollbar">
      <!-- JS will inject output lines here -->
    </div>

    <!-- Terminal Input Area -->
    <div class="flex items-center px-5 py-4 border-t border-green-500/20 bg-[#161b22]">
      <span class="text-green-500 mr-2 font-bold">❯</span>
      <input 
        id="terminal-input" 
        type="text" 
        class="flex-1 bg-transparent outline-none text-green-300 caret-green-400 placeholder-green-800" 
        placeholder="Type 'help' to get started..." 
        autocomplete="off" 
        spellcheck="false"
      />
    </div>
  </div>
</div>

<style>
  /* ========================================== */
  /* PREMIUM MOUSE GLOW SPOTLIGHT               */
  /* ========================================== */
  .glow-card {
    position: relative;
    overflow: hidden;
  }
  
  .glow-card::before {
    content: '';
    position: absolute;
    inset-block-start: var(--mouse-y, 50%);
    inset-inline-start: var(--mouse-x, 50%);
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, rgba(59, 130, 246, 0.15) 0%, transparent 70%);
    transform: translate(-50%, -50%);
    opacity: 0;
    transition: opacity 0.4s ease;
    pointer-events: none;
    z-index: 0;
  }
  
  .glow-card:hover::before {
    opacity: 1;
  }
  
  /* Ensure text stays above the glow */
  .glow-card > * {
    position: relative;
    z-index: 1;
  }

  /* Custom scrollbar for the terminal */
  .custom-scrollbar::-webkit-scrollbar { width: 6px; }
  .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
  .custom-scrollbar::-webkit-scrollbar-thumb { background: rgba(34, 197, 94, 0.3); border-radius: 3px; }
  
  /* Fade in animation for the overlay */
  @keyframes fade-in { from { opacity: 0; } to { opacity: 1; } }
  .animate-fade-in { animation: fade-in 0.2s ease-out forwards; }
</style>

<script define:vars={{ commandsJSON }}>
  // 1. Parse the JSON commands
  const commands = JSON.parse(commandsJSON);
  
  // 2. DOM Elements
  const terminal = document.getElementById('cyber-terminal');
  const output = document.getElementById('terminal-output');
  const input = document.getElementById('terminal-input');
  const closeBtn = document.getElementById('close-terminal');

  // 3. State Variables
  let history = [];
  let historyIndex = -1;

  // 4. Toggle Terminal
  function toggleTerminal() {
    const isHidden = terminal.classList.contains('hidden');
    if (isHidden) {
      terminal.classList.remove('hidden');
      input.focus();
      printLine("<span class='text-cyan-400'>Welcome to zxsprd secure shell.</span>", false);
      printLine("System initialized. Type <span class='text-white font-bold'>'help'</span> for commands, or press <span class='text-white font-bold'>[TAB]</span> for autocomplete.", false);
      printLine("", false);
    } else {
      terminal.classList.add('hidden');
    }
  }
  window.openTerminal = toggleTerminal;

  // 5. Keyboard Shortcuts
  document.addEventListener('keydown', (e) => {
    if ((e.ctrlKey && e.key.toLowerCase() === 'k') || e.key === '~') {
      e.preventDefault();
      toggleTerminal();
    }
    if (e.key === 'Escape' && !terminal.classList.contains('hidden')) {
      toggleTerminal();
    }
  });
  closeBtn?.addEventListener('click', toggleTerminal);

  // 6. Input Event Listeners (Enter, Tab, Arrows)
  input.addEventListener('keydown', async (e) => {
    // ENTER: Execute Command
    if (e.key === 'Enter') {
      const rawCmd = input.value;
      if (rawCmd.trim() !== '') {
        history.push(rawCmd);
        historyIndex = history.length;
      }
      printLine(`<span class='text-green-500 font-bold'>❯</span> <span class='text-white'>${rawCmd}</span>`, false);
      await processCommand(rawCmd);
      input.value = '';
    } 
    // TAB: Autocomplete
    else if (e.key === 'Tab') {
      e.preventDefault();
      const val = input.value.trim();
      if (val) {
        const matches = commands.filter(c => c.cmd.startsWith(val));
        if (matches.length === 1) {
          input.value = matches[0].cmd + ' ';
        } else if (matches.length > 1) {
          printLine(matches.map(m => `<span class='text-white'>${m.cmd}</span>`).join('  '), false);
        }
      }
    } 
    // ARROW UP/DOWN: History
    else if (e.key === 'ArrowUp') {
      e.preventDefault();
      if (historyIndex > 0) {
        historyIndex--;
        input.value = history[historyIndex];
      }
    } else if (e.key === 'ArrowDown') {
      e.preventDefault();
      if (historyIndex < history.length - 1) {
        historyIndex++;
        input.value = history[historyIndex];
      } else {
        historyIndex = history.length;
        input.value = '';
      }
    }
  });

  // 7. Print Line Helper
  function printLine(html, addMargin = true) {
    const line = document.createElement('div');
    line.className = `text-green-400 ${addMargin ? 'mb-1' : ''}`;
    line.innerHTML = html;
    output.appendChild(line);
    output.scrollTop = output.scrollHeight;
  }

  // 8. Command Router (The Brain)
  async function processCommand(rawInput) {
    const parts = rawInput.trim().split(' ');
    const cmdStr = parts[0].toLowerCase();
    const args = parts.slice(1).join(' ');

    const cmdObj = commands.find(c => c.cmd === cmdStr);

    if (!cmdObj) {
      if (cmdStr !== '') printLine(`<span class='text-red-400'>Command not found:</span> ${cmdStr}. Type 'help' for options.`);
      return;
    }

    // Handle System Commands
    if (cmdObj.type === 'system') {
      if (cmdObj.action === 'clear') output.innerHTML = '';
      else if (cmdObj.action === 'exit') toggleTerminal();
      else if (cmdObj.action === 'help') {
        printLine("<span class='text-yellow-400 font-bold underline'>Available Commands:</span>");
        commands.forEach(c => {
          printLine(`  <span class='text-white w-24 inline-block'>${c.cmd}</span> - ${c.desc}`);
        });
      }
      else if (cmdObj.action === 'matrix') {
        printLine("<span class='text-green-500'>Wake up, Neo... The Matrix has you...</span>");
      }
      return;
    }

    // Handle Info & Easter Eggs
    if (cmdObj.type === 'info' || cmdObj.type === 'easter_egg') {
      cmdObj.output.forEach(line => printLine(line));
      return;
    }

    // Handle Navigation & Links
    if (cmdObj.type === 'navigate') {
      printLine(`<span class='text-green-500'>Navigating to ${cmdObj.url}...</span>`);
      setTimeout(() => window.location.href = cmdObj.url, 500);
      return;
    }
    if (cmdObj.type === 'link') {
      printLine(`<span class='text-green-500'>Opening ${cmdObj.url} in new tab...</span>`);
      window.open(cmdObj.url, '_blank');
      return;
    }

    // Handle Utilities (Requires Arguments)
    if (cmdObj.type === 'utility') {
      if (!args) {
        printLine(`<span class='text-red-400'>Error:</span> Missing arguments. Usage: ${cmdObj.desc}`);
        return;
      }
      await runUtility(cmdObj.action, args);
    }
  }

  // 9. Utility Functions (The Swiss Army Knife)
  async function runUtility(action, args) {
    try {
      if (action === 'sha256') {
        const msgUint8 = new TextEncoder().encode(args);
        const hashBuffer = await crypto.subtle.digest('SHA-256', msgUint8);
        const hashArray = Array.from(new Uint8Array(hashBuffer));
        const hashHex = hashArray.map(b => b.toString(16).padStart(2, '0')).join('');
        printLine(`<span class='text-cyan-400'>SHA-256:</span> <span class='text-white'>${hashHex}</span>`);
      } 
      else if (action === 'base64') {
        const encoded = btoa(args);
        printLine(`<span class='text-cyan-400'>Base64:</span> <span class='text-white'>${encoded}</span>`);
      } 
      else if (action === 'genpass') {
        const len = parseInt(args) || 16;
        const chars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789!@#$%^&*';
        let pass = '';
        const arr = new Uint8Array(len);
        crypto.getRandomValues(arr);
        arr.forEach(val => pass += chars[val % chars.length]);
        printLine(`<span class='text-cyan-400'>Password (${len}):</span> <span class='text-white'>${pass}</span>`);
      } 
      else if (action === 'jwt') {
        const parts = args.split('.');
        if (parts.length !== 3) throw new Error('Invalid JWT format');
        const header = JSON.parse(atob(parts[0].replace(/-/g, '+').replace(/_/g, '/')));
        const payload = JSON.parse(atob(parts[1].replace(/-/g, '+').replace(/_/g, '/')));
        printLine(`<span class='text-cyan-400'>Header:</span> <span class='text-white'>${JSON.stringify(header)}</span>`);
        printLine(`<span class='text-cyan-400'>Payload:</span> <span class='text-white'>${JSON.stringify(payload)}</span>`);
      } 
      else if (action === 'urlencode') {
        printLine(`<span class='text-cyan-400'>URL Encoded:</span> <span class='text-white'>${encodeURIComponent(args)}</span>`);
      } 
      else if (action === 'whois') {
        printLine(`<span class='text-yellow-400'>[MOCK]</span> Fetching WHOIS data for ${args}...`);
        printLine(`Domain: ${args}`);
        printLine(`Registrar: GoDaddy`);
        printLine(`Creation Date: 2021-01-01`);
        printLine(`Status: clientTransferProhibited`);
      } 
      else if (action === 'ping') {
        printLine(`PING ${args} (93.184.216.34) 56(84) bytes of data.`);
        for(let i=1; i<=4; i++) {
          await new Promise(r => setTimeout(r, 300));
          printLine(`64 bytes from ${args}: icmp_seq=${i} ttl=56 time=${(Math.random() * 50 + 10).toFixed(1)} ms`);
        }
        printLine(`\n--- ${args} ping statistics ---`);
        printLine(`4 packets transmitted, 4 received, 0% packet loss`);
      }
	        // --- NEW WORKING UTILITIES ---

      else if (action === 'ip') {
        printLine(`<span class='text-yellow-400'>Fetching public IP...</span>`);
        try {
          const res = await fetch('https://api.ipify.org?format=json');
          const data = await res.json();
          printLine(`<span class='text-cyan-400'>Public IP:</span> <span class='text-white font-bold'>${data.ip}</span>`);
        } catch {
          printLine(`<span class='text-red-400'>[ERROR]</span> Could not reach IP service. Check your connection.`);
        }
      } 
      else if (action === 'sysinfo') {
        printLine(`<span class='text-cyan-400'>User Agent:</span> <span class='text-white text-xs'>${navigator.userAgent}</span>`);
        printLine(`<span class='text-cyan-400'>Platform:</span> <span class='text-white'>${navigator.platform || 'Unknown'}</span>`);
        printLine(`<span class='text-cyan-400'>Language:</span> <span class='text-white'>${navigator.language}</span>`);
        printLine(`<span class='text-cyan-400'>Screen:</span> <span class='text-white'>${window.screen.width} x ${window.screen.height}</span>`);
        printLine(`<span class='text-cyan-400'>Window:</span> <span class='text-white'>${window.innerWidth} x ${window.innerHeight}</span>`);
        printLine(`<span class='text-cyan-400'>Cores:</span> <span class='text-white'>${navigator.hardwareConcurrency || 'Unknown'}</span>`);
        printLine(`<span class='text-cyan-400'>Memory:</span> <span class='text-white'>${navigator.deviceMemory ? navigator.deviceMemory + ' GB' : 'Restricted'}</span>`);
      } 
      else if (action === 'time') {
        const now = new Date();
        printLine(`<span class='text-cyan-400'>Local Time:</span> <span class='text-white'>${now.toLocaleString()}</span>`);
        printLine(`<span class='text-cyan-400'>UTC Time:</span> <span class='text-white'>${now.toUTCString()}</span>`);
        printLine(`<span class='text-cyan-400'>Unix Epoch:</span> <span class='text-white font-bold'>${Math.floor(now.getTime() / 1000)}</span>`);
      } 
      else if (action === 'hex') {
        const hexStr = Array.from(args).map(c => c.charCodeAt(0).toString(16).padStart(2, '0')).join(' ');
        printLine(`<span class='text-cyan-400'>Hex:</span> <span class='text-white'>${hexStr}</span>`);
      } 
      else if (action === 'unhex') {
        const cleanHex = args.replace(/\s+/g, '');
        let str = '';
        for (let i = 0; i < cleanHex.length; i += 2) {
          str += String.fromCharCode(parseInt(cleanHex.substr(i, 2), 16));
        }
        printLine(`<span class='text-cyan-400'>Text:</span> <span class='text-white'>${str}</span>`);
      } 
      else if (action === 'b64dec') {
        const decoded = atob(args);
        printLine(`<span class='text-cyan-400'>Decoded:</span> <span class='text-white'>${decoded}</span>`);
      } 
      else if (action === 'urldec') {
        const decoded = decodeURIComponent(args);
        printLine(`<span class='text-cyan-400'>Decoded:</span> <span class='text-white'>${decoded}</span>`);
      } 
      else if (action === 'json') {
        const parsed = JSON.parse(args);
        const pretty = JSON.stringify(parsed, null, 2);
        // Split by new line to print nicely in terminal
        pretty.split('\n').forEach(line => {
          printLine(`<span class='text-white'>${line.replace(/"/g, "<span class='text-green-400'>\"</span>").replace(/:/g, "<span class='text-green-400'>:</span>")}</span>`);
        });
      }
	  
    } catch (err) {
      printLine(`<span class='text-red-400'>[ERROR]</span> ${err.message}`);
    }
  }
</script>

   <Footer />
   <KonamiEgg />
     <ThemeSwitcher />
  </body>
</html>