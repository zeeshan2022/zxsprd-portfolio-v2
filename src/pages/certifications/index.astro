---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import certData from '../../data/certifications.json';
import fs from 'node:fs';
import path from 'node:path';

// 📁 Scan the public/certifications folder at build time
const publicCertPath = path.join(process.cwd(), 'public', 'certifications');
let publicFiles = [];

try {
  if (fs.existsSync(publicCertPath)) {
    publicFiles = fs.readdirSync(publicCertPath);
  }
} catch (e) {
  console.warn('⚠️ Could not read public/certifications folder:', e.message);
}

// 🔄 Map JSON data to actual files in the public folder
const certifications = certData.map(cert => {
  const fileExists = publicFiles.includes(cert.filename);
  
  return {
    ...cert,
    // Image path is served directly from public folder
    imageSrc: fileExists ? `/certifications/${cert.filename}` : null,
    hasImage: fileExists
  };
});

// ✅ Filter out entries where image is missing
const validCerts = certifications.filter(cert => cert.hasImage);
---

<Layout title="Professional Certifications | ZX Labs" lang="en" dir="ltr">
  <Navbar currentLang="en" />

  <main class="min-h-screen pt-24 px-6 pb-20">
    <div class="max-w-7xl mx-auto">
      
      <!-- Header -->
      <div class="text-center mb-16 reveal">
        <h1 class="text-4xl md:text-5xl font-bold text-text mb-4">
          Professional <span class="text-accent">Certifications</span>
        </h1>
        <p class="text-muted max-w-2xl mx-auto text-lg">
          A collection of verified credentials, continuous learning, and industry-recognized qualifications in Cybersecurity, Cloud, and Risk Management.
        </p>
        <div class="mt-6 inline-flex items-center gap-2 px-4 py-2 bg-accent/10 border border-accent/30 rounded-full text-sm text-accent">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
          {validCerts.length} Verified Certifications
        </div>
      </div>

      <!-- Interactive Gallery Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {validCerts.map((cert, index) => (
          <div 
            class="group glass-card rounded-2xl overflow-hidden border border-border hover:border-accent/50 transition-all duration-500 cursor-pointer reveal"
            style={`animation-delay: ${index * 150}ms`}
            data-index={index}
            data-title={cert.title}
            data-issuer={cert.issuer}
            data-date={cert.date}
            data-credential={cert.credentialId}
            data-category={cert.category}
          >
            <!-- Image Container with Hover Effect -->
            <div class="relative h-80 overflow-hidden bg-gradient-to-br from-bg to-bg/50">
              <img 
                src={`/certifications/${cert.filename}`} 
                alt={cert.title}
                class="w-full h-full object-contain p-6 group-hover:scale-110 transition-transform duration-700 ease-out"
                loading="lazy"
              />
              
              <!-- Hover Overlay -->
              <div class="absolute inset-0 bg-gradient-to-t from-bg via-bg/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex items-end p-6">
                <div class="flex items-center gap-2 text-accent">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM10 7v3m0 0v3m0-3h3m-3 0H7"></path></svg>
                  <span class="text-sm font-bold uppercase tracking-wider">Click to Expand</span>
                </div>
              </div>

              <!-- Category Badge -->
              <div class="absolute top-4 right-4 px-3 py-1 bg-accent/90 text-bg text-xs font-bold rounded-full backdrop-blur-sm">
                {cert.category}
              </div>
            </div>

            <!-- Info Card -->
            <div class="p-6 space-y-3">
              <h3 class="text-lg font-bold text-text group-hover:text-accent transition-colors line-clamp-2">
                {cert.title}
              </h3>
              
              <div class="flex items-center justify-between text-sm text-muted">
                <span class="flex items-center gap-2">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path></svg>
                  {cert.issuer}
                </span>
                <span class="flex items-center gap-2">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                  {cert.date}
                </span>
              </div>

              <div class="pt-3 border-t border-border/50">
                <span class="text-xs font-mono text-muted">ID: {cert.credentialId}</span>
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- Empty State -->
      {validCerts.length === 0 && (
        <div class="text-center py-20">
          <div class="inline-flex items-center justify-center w-20 h-20 bg-accent/10 rounded-full mb-6">
            <svg class="w-10 h-10 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
          </div>
          <h3 class="text-xl font-bold text-text mb-2">No Certifications Found</h3>
          <p class="text-muted">Make sure your images are in the correct folder and filenames match the JSON.</p>
        </div>
      )}

    </div>

    <!-- Full-Screen Interactive Lightbox -->
    <div id="lightbox" class="fixed inset-0 z-[100] bg-black/95 backdrop-blur-md hidden items-center justify-center p-4 md:p-8">
      
      <!-- Close Button -->
      <button id="lightbox-close" class="absolute top-6 right-6 text-white/70 hover:text-white transition-colors z-10">
        <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
      </button>

      <!-- Navigation Buttons -->
      <button id="lightbox-prev" class="absolute left-6 top-1/2 -translate-y-1/2 text-white/70 hover:text-white transition-colors z-10 hidden md:block">
        <svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
      </button>
      <button id="lightbox-next" class="absolute right-6 top-1/2 -translate-y-1/2 text-white/70 hover:text-white transition-colors z-10 hidden md:block">
        <svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
      </button>

      <!-- Content Container -->
      <div class="max-w-6xl w-full max-h-[90vh] flex flex-col items-center">
        
        <!-- Image Container with Zoom -->
        <div class="relative flex-1 w-full flex items-center justify-center overflow-hidden">
          <img 
            id="lightbox-img" 
            src="" 
            alt="" 
            class="max-w-full max-h-[70vh] object-contain rounded-xl shadow-2xl shadow-black/50 transition-transform duration-300 cursor-zoom-in"
          />
        </div>

        <!-- Info Panel -->
        <div class="mt-6 text-center space-y-2 max-w-2xl">
          <h2 id="lightbox-title" class="text-2xl md:text-3xl font-bold text-white"></h2>
          <div class="flex items-center justify-center gap-4 text-sm text-gray-400">
            <span id="lightbox-issuer" class="flex items-center gap-2">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path></svg>
            </span>
            <span class="text-gray-600">•</span>
            <span id="lightbox-date" class="flex items-center gap-2">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
            </span>
          </div>
          <p id="lightbox-credential" class="text-xs font-mono text-gray-500"></p>
        </div>

      </div>
    </div>
  </main>

  <script>
    // Lightbox functionality
    const lightbox = document.getElementById('lightbox');
    const lightboxImg = document.getElementById('lightbox-img');
    const lightboxTitle = document.getElementById('lightbox-title');
    const lightboxIssuer = document.getElementById('lightbox-issuer');
    const lightboxDate = document.getElementById('lightbox-date');
    const lightboxCredential = document.getElementById('lightbox-credential');
    const lightboxClose = document.getElementById('lightbox-close');
    const lightboxPrev = document.getElementById('lightbox-prev');
    const lightboxNext = document.getElementById('lightbox-next');
    
    let currentIndex = 0;
    let isZoomed = false;
    const cards = document.querySelectorAll('[data-index]');

    // Open lightbox
    cards.forEach(card => {
      card.addEventListener('click', () => {
        currentIndex = parseInt(card.getAttribute('data-index'));
        openLightbox(currentIndex);
      });
    });

    function openLightbox(index) {
      const card = cards[index];
      const img = card.querySelector('img');
      
      lightboxImg.src = img.src;
      lightboxImg.alt = card.getAttribute('data-title');
      lightboxTitle.textContent = card.getAttribute('data-title');
      lightboxIssuer.innerHTML = `
        <svg class="w-4 h-4 inline" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path></svg>
        ${card.getAttribute('data-issuer')}
      `;
      lightboxDate.innerHTML = `
        <svg class="w-4 h-4 inline" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
        ${card.getAttribute('data-date')}
      `;
      lightboxCredential.textContent = `Credential ID: ${card.getAttribute('data-credential')}`;
      
      lightbox.classList.remove('hidden');
      lightbox.classList.add('flex');
      document.body.style.overflow = 'hidden';
      
      // Reset zoom
      isZoomed = false;
      lightboxImg.style.transform = 'scale(1)';
    }

    function closeLightbox() {
      lightbox.classList.add('hidden');
      lightbox.classList.remove('flex');
      document.body.style.overflow = '';
    }

    function navigateLightbox(direction) {
      currentIndex = (currentIndex + direction + cards.length) % cards.length;
      openLightbox(currentIndex);
    }

    // Zoom functionality
    lightboxImg.addEventListener('click', (e) => {
      e.stopPropagation();
      isZoomed = !isZoomed;
      lightboxImg.style.transform = isZoomed ? 'scale(1.5)' : 'scale(1)';
      lightboxImg.style.cursor = isZoomed ? 'zoom-out' : 'zoom-in';
    });

    // Event listeners
    lightboxClose.addEventListener('click', closeLightbox);
    lightboxPrev.addEventListener('click', () => navigateLightbox(-1));
    lightboxNext.addEventListener('click', () => navigateLightbox(1));
    
    lightbox.addEventListener('click', (e) => {
      if (e.target === lightbox) closeLightbox();
    });

    // Keyboard navigation
    document.addEventListener('keydown', (e) => {
      if (!lightbox.classList.contains('hidden')) {
        if (e.key === 'Escape') closeLightbox();
        if (e.key === 'ArrowLeft') navigateLightbox(-1);
        if (e.key === 'ArrowRight') navigateLightbox(1);
      }
    });
  </script>
</Layout>