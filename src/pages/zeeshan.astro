---
// No complex imports. Everything is right here.
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Zeeshan Haider | Digital Card</title>
  <meta name="description" content="Digital Business Card for Zeeshan Haider" />
  <!-- Tailwind CSS is automatically injected by Astro -->
</head>
<body class="bg-[#0f172a] text-gray-100 min-h-screen flex items-center justify-center p-4">
  
  <main class="w-full max-w-md glass-card rounded-3xl border border-white/10 bg-white/5 backdrop-blur-xl p-8 text-center shadow-2xl shadow-black/50">
    
    <!-- Profile Image -->
    <div class="w-32 h-32 mx-auto rounded-full bg-blue-500/20 border-2 border-blue-400 flex items-center justify-center mb-6 overflow-hidden">
      <!-- Replace 'zeeshan.jpg' with your actual image in the public folder -->
      <img src="/zeeshan.jpg" alt="Zeeshan Haider" class="w-full h-full object-cover" onerror="this.style.display='none'; this.nextElementSibling.style.display='flex'" />
      <span class="text-4xl font-bold text-blue-400 hidden">ZH</span>
    </div>

    <!-- Name & Title -->
    <h1 class="text-3xl font-bold text-white mb-2">Zeeshan Haider</h1>
    <p class="text-blue-400 font-semibold tracking-wide uppercase text-sm mb-8">Cybersecurity & Cloud Architect</p>

    <!-- Quick Action Buttons -->
    <div class="space-y-4 mb-8">
      <a href="mailto:zeeshan@zxsprd.com" class="flex items-center justify-center gap-3 w-full px-6 py-4 bg-blue-600 text-white font-bold rounded-xl hover:bg-blue-500 transition-all shadow-lg shadow-blue-500/20">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
        Email Me
      </a>
      
      <a href="https://linkedin.com/in/zeeshanhaider" target="_blank" class="flex items-center justify-center gap-3 w-full px-6 py-4 bg-white/5 border border-white/10 text-white font-bold rounded-xl hover:border-blue-400 hover:text-blue-400 transition-all">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
        Connect on LinkedIn
      </a>
    </div>

    <!-- WeChat / QR Code Section -->
    <div class="pt-6 border-t border-white/10">
      <p class="text-xs text-gray-400 uppercase tracking-widest mb-4">Scan to Connect on WeChat</p>
      <div class="w-48 h-48 mx-auto bg-white rounded-2xl p-3 shadow-inner">
        <!-- Replace 'wechat-zeeshan.jpg' with your actual QR code image -->
        <img src="/wechat-zeeshan.jpg" alt="WeChat QR" class="w-full h-full object-contain rounded-xl" onerror="this.src='https://api.qrserver.com/v1/create-qr-code/?size=200x200&data=WeChatID_Zeeshan'" />
      </div>
    </div>

    <!-- Footer -->
    <div class="mt-8 pt-6 border-t border-white/10">
      <p class="text-[10px] text-gray-500">© 2024 ZX Labs. Securely Hosted.</p>
    </div>
  </main>
</body>
</html>