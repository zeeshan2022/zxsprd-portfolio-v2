---
---
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
		<title>Interactive Webcam Exploder</title>
		<style>
			:root {
				--bg-color: #030307;
				--accent-color: #a855f7;
			}
			body, html {
				margin: 0;
				padding: 0;
				width: 100%;
				height: 100%;
				overflow: hidden;
				background-color: var(--bg-color);
				font-family: system-ui, sans-serif;
				touch-action: none;
			}
			canvas {
				position: absolute;
				top: 0;
				left: 0;
				width: 100%;
				height: 100%;
				display: block;
			}
			video {
				display: none; /* Hidden source stream used purely for pixel color sampling */
			}
			.ui-layer {
				position: absolute;
				top: 20px;
				left: 20px;
				color: #fff;
				z-index: 10;
				pointer-events: none;
				user-select: none;
			}
			h1 {
				margin: 0 0 5px 0;
				font-size: 1.6rem;
				letter-spacing: 1px;
				color: var(--accent-color);
				text-shadow: 0 0 10px rgba(168, 85, 247, 0.4);
			}
			p {
				margin: 0;
				font-size: 0.85rem;
				color: #71717a;
			}
			.start-overlay {
				position: absolute;
				inset: 0;
				background: rgba(3, 3, 7, 0.95);
				display: flex;
				justify-content: center;
				align-items: center;
				z-index: 100;
			}
			.start-btn {
				background: transparent;
				border: 1px solid var(--accent-color);
				color: var(--accent-color);
				padding: 14px 28px;
				font-size: 1rem;
				border-radius: 4px;
				cursor: pointer;
				text-transform: uppercase;
				letter-spacing: 2px;
				transition: all 0.3s ease;
				box-shadow: 0 0 15px rgba(168, 85, 247, 0.2);
			}
			.start-btn:hover {
				background: var(--accent-color);
				color: #fff;
				box-shadow: 0 0 25px rgba(168, 85, 247, 0.6);
			}
		</style>
	</head>
	<body>

		<div class="start-overlay" id="overlay">
			<button class="start-btn" id="startBtn">Mirror Particles</button>
		</div>

		<div class="ui-layer">
			<h1>Pixel Exploder</h1>
			<p>Drag or swipe across the stream viewport to tear your image apart.</p>
		</div>

		<video id="webcam" autoplay playsinline muted></video>
		<!-- Double buffered canvas strategy: One hidden downsampler, one master renderer -->
		<canvas id="render-canvas"></canvas>

		<script>
			const canvas = document.getElementById('render-canvas') as HTMLCanvasElement;
			const ctx = canvas.getContext('2d')!;
			const video = document.getElementById('webcam') as HTMLVideoElement;
			const startBtn = document.getElementById('startBtn')!;
			const overlay = document.getElementById('overlay')!;

			// Create hidden utility canvas to scale down the webcam input frame context
			const videoCanvas = document.createElement('canvas');
			const videoCtx = videoCanvas.getContext('2d', { willReadFrequently: true })!;

			let width = canvas.width = window.innerWidth;
			let height = canvas.height = window.innerHeight;

			// Controls resolution mapping density. Lower equals more points (heavier load)
			const sampleGridSpacing = 6; 
			let particles: Particle[] = [];
			let isStreamLive = false;

			const mouse = { x: -1000, y: -1000, radius: 100, active: false };

			class Particle {
				originX: number;
				originY: number;
				x: number;
				y: number;
				vx: number;
				vy: number;
				color: string;
				friction: number;
				springStrength: number;

				constructor(x: number, y: number) {
					this.originX = x;
					this.originY = y;
					this.x = Math.random() * width; // Spawn scattered across the screen
					this.y = Math.random() * height;
					this.vx = 0;
					this.vy = 0;
					this.color = 'rgb(0,0,0)';
					this.friction = 0.85;
					this.springStrength = 0.05;
				}

				update() {
					// Mouse interaction physics (repulsion force)
					if (mouse.active) {
						const dx = this.x - mouse.x;
						const dy = this.y - mouse.y;
						const dist = Math.hypot(dx, dy);

						if (dist < mouse.radius) {
							const force = (mouse.radius - dist) / mouse.radius;
							const angle = Math.atan2(dy, dx);
							// Push particles away rapidly based on proximity
							this.vx += Math.cos(angle) * force * 12;
							this.vy += Math.sin(angle) * force * 12;
						}
					}

					// Spring matrix physics returning elements back to original camera slot assignments
					const homeDx = this.originX - this.x;
					const homeDy = this.originY - this.y;
					this.vx += homeDx * this.springStrength;
					this.vy += homeDy * this.springStrength;

					// Apply velocity drag friction
					this.vx *= this.friction;
					this.vy *= this.friction;

					this.x += this.vx;
					this.y += this.vy;
				}

				draw() {
					ctx.fillStyle = this.color;
					ctx.fillRect(this.x, this.y, sampleGridSpacing - 1, sampleGridSpacing - 1);
				}
			}

			async function initWebcam() {
				try {
					const stream = await navigator.mediaDevices.getUserMedia({
						audio: false,
						video: { width: { ideal: 640 }, height: { ideal: 480 } }
					});

					video.srcObject = stream;
					video.onloadedmetadata = () => {
						video.play();
						
						// Lock internal frame canvas size to sample grid scale maps
						videoCanvas.width = 160;
						videoCanvas.height = 120;
						
						generateParticleGrid();
						isStreamLive = true;
						overlay.style.display = 'none';
						animate();
					};
				} catch (err) {
					alert('Webcam stream authorization declined or unavailable.');
					console.error(err);
				}
			}

			function generateParticleGrid() {
				particles = [];
				// Map aspect ratios between viewport limits and downscaled canvas inputs
				const stepX = width / videoCanvas.width;
				const stepY = height / videoCanvas.height;

				for (let y = 0; y < videoCanvas.height; y++) {
					for (let x = 0; x < videoCanvas.width; x++) {
						// Setup point grid coordinate positions centered into the canvas viewport
						particles.push(new Particle(x * stepX, y * stepY));
					}
				}
			}

			startBtn.addEventListener('click', initWebcam);

			function animate() {
				// Clean screen clearing loop
				ctx.fillStyle = '#030307';
				ctx.fillRect(0, 0, width, height);

				if (!isStreamLive) return;

				// 1. Draw hidden source frame state
				videoCtx.drawImage(video, 0, 0, videoCanvas.width, videoCanvas.height);
				// Extract multi-layered binary data array grid blocks
				const imgData = videoCtx.getImageData(0, 0, videoCanvas.width, videoCanvas.height).data;

				// 2. Loop and map calculated visual structures into particles array
				for (let i = 0; i < particles.length; i++) {
					const p = particles[i];
					
					// Find relative index inside Uint8ClampedArray
					// We calculate coordinates based on internal layout index variables
					const internalX = Math.floor(p.originX / (width / videoCanvas.width));
					const internalY = Math.floor(p.originY / (height / videoCanvas.height));
					
					// Horizontal reflection flip processing mapping formula
					const mirroredX = (videoCanvas.width - 1) - internalX;
					const pixelArrayIndexPosition = (internalY * videoCanvas.width + mirroredX) * 4;

					// Grab RGB parameters out of current video pixel positions
					const r = imgData[pixelArrayIndexPosition];
					const g = imgData[pixelArrayIndexPosition + 1];
					const b = imgData[pixelArrayIndexPosition + 2];

					p.color = `rgb(${r},${g},${b})`;
					p.update();
					p.draw();
				}

				requestAnimationFrame(animate);
			}

			// Interaction Event Routing Setup Hooks
			function updateTracking(x: number, y: number, isActive: boolean) {
				mouse.x = x;
				mouse.y = y;
				mouse.active = isActive;
			}

			window.addEventListener('mousemove', (e) => updateTracking(e.clientX, e.clientY, true));
			window.addEventListener('mouseleave', () => mouse.active = false);

			window.addEventListener('touchmove', (e) => {
				if (e.touches.length > 0) {
					updateTracking(e.touches[0].clientX, e.touches[0].clientY, true);
				}
			}, { passive: true });
			window.addEventListener('touchend', () => mouse.active = false);

			window.addEventListener('resize', () => {
				width = canvas.width = window.innerWidth;
				height = canvas.height = window.innerHeight;
				generateParticleGrid();
			});
		</script>
	</body>
</html>
