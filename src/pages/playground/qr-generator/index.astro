---
import Layout from '../../../layouts/Layout.astro';
import Navbar from '../../../components/Navbar.astro';
---
<style>
  /* Force the generated QR code to fit its container visually without overlapping */
  #qr-container canvas, 
  #qr-container svg {
    max-width: 100% !important;
    height: auto !important;
    display: block;
    margin: 0 auto;
  }
</style>

<Layout title="Universal QR Generator | ZX Labs" lang="en" dir="ltr">
  <Navbar currentLang="en" />

  <main class="min-h-screen pt-24 px-6 pb-20">
    <div class="max-w-6xl mx-auto">
      
      <!-- Header -->
      <div class="text-center mb-12 reveal">
        <h1 class="text-3xl md:text-4xl font-bold text-text mb-4">
          Universal <span class="text-accent">QR Studio</span>
        </h1>
        <p class="text-muted">Generate highly customized QR codes for Wi-Fi, URLs, Text, and more.</p>
      </div>

      <div class="grid lg:grid-cols-5 gap-8">
        
        <!-- Left Column: Controls (3/5 width) -->
        <div class="lg:col-span-3 glass-card rounded-2xl p-6 md:p-8 border border-border reveal space-y-6">
          
          <!-- 1. Data Type Tabs -->
          <div>
            <h2 class="text-lg font-bold text-text mb-4">1. Select Data Type</h2>
            <div class="flex flex-wrap gap-2" id="type-tabs">
              <button data-type="wifi" class="tab-btn active px-4 py-2 rounded-lg text-sm font-semibold transition-all bg-accent text-bg">Wi-Fi</button>
              <button data-type="url" class="tab-btn px-4 py-2 rounded-lg text-sm font-semibold transition-all bg-bg border border-border text-text hover:border-accent">URL</button>
              <button data-type="text" class="tab-btn px-4 py-2 rounded-lg text-sm font-semibold transition-all bg-bg border border-border text-text hover:border-accent">Text</button>
              <button data-type="email" class="tab-btn px-4 py-2 rounded-lg text-sm font-semibold transition-all bg-bg border border-border text-text hover:border-accent">Email</button>
              <button data-type="phone" class="tab-btn px-4 py-2 rounded-lg text-sm font-semibold transition-all bg-bg border border-border text-text hover:border-accent">Phone</button>
            </div>
          </div>

          <!-- 2. Dynamic Input Fields -->
          <div id="input-section" class="pt-4 border-t border-border">
            <h2 class="text-lg font-bold text-text mb-4">2. Enter Details</h2>
            
            <div id="form-wifi" class="form-panel space-y-4">
              <input id="wifi-ssid" type="text" placeholder="Network Name (SSID)" class="w-full px-4 py-3 bg-bg border border-border rounded-lg text-text focus:outline-none focus:border-accent" />
              <input id="wifi-pass" type="text" placeholder="Password" class="w-full px-4 py-3 bg-bg border border-border rounded-lg text-text focus:outline-none focus:border-accent" />
              <div class="grid grid-cols-2 gap-4">
                <select id="wifi-enc" class="px-4 py-3 bg-bg border border-border rounded-lg text-text focus:outline-none focus:border-accent">
                  <option value="WPA">WPA/WPA2</option>
                  <option value="WEP">WEP</option>
                  <option value="nopass">None (Open)</option>
                </select>
                <label class="flex items-center gap-3 px-4 py-3 bg-bg border border-border rounded-lg cursor-pointer">
                  <input id="wifi-hidden" type="checkbox" class="w-4 h-4 text-accent" />
                  <span class="text-sm text-text">Hidden Network</span>
                </label>
              </div>
            </div>

            <div id="form-url" class="form-panel hidden space-y-4">
              <input id="url-val" type="url" placeholder="https://zxsprd.com" class="w-full px-4 py-3 bg-bg border border-border rounded-lg text-text focus:outline-none focus:border-accent" />
            </div>

            <div id="form-text" class="form-panel hidden space-y-4">
              <textarea id="text-val" rows="4" placeholder="Enter your plain text here..." class="w-full px-4 py-3 bg-bg border border-border rounded-lg text-text focus:outline-none focus:border-accent resize-none"></textarea>
            </div>

            <div id="form-email" class="form-panel hidden space-y-4">
              <input id="email-addr" type="email" placeholder="recipient@example.com" class="w-full px-4 py-3 bg-bg border border-border rounded-lg text-text focus:outline-none focus:border-accent" />
              <input id="email-sub" type="text" placeholder="Subject (Optional)" class="w-full px-4 py-3 bg-bg border border-border rounded-lg text-text focus:outline-none focus:border-accent" />
              <textarea id="email-body" rows="3" placeholder="Message body (Optional)" class="w-full px-4 py-3 bg-bg border border-border rounded-lg text-text focus:outline-none focus:border-accent resize-none"></textarea>
            </div>

            <div id="form-phone" class="form-panel hidden space-y-4">
              <input id="phone-val" type="tel" placeholder="+971 58 203 5980" class="w-full px-4 py-3 bg-bg border border-border rounded-lg text-text focus:outline-none focus:border-accent" />
            </div>
          </div>

          <!-- 3. Design & Customization -->
          <div class="pt-6 border-t border-border">
            <h2 class="text-lg font-bold text-text mb-4">3. Design & Customization</h2>
            
            <div class="grid grid-cols-2 gap-4 mb-4">
              <div>
                <label class="block text-sm font-medium text-muted mb-2">Foreground</label>
                <div class="flex gap-2">
                  <input id="color-fg" type="color" value="#0A0178" class="h-10 w-12 bg-transparent border border-border rounded cursor-pointer" />
                  <input id="color-fg-hex" type="text" value="#0A0178" class="flex-1 px-3 py-2 bg-bg border border-border rounded-lg text-text text-sm font-mono focus:outline-none focus:border-accent" />
                </div>
              </div>
              <div>
                <label class="block text-sm font-medium text-muted mb-2">Background</label>
                <div class="flex gap-2">
                  <input id="color-bg" type="color" value="#FFFFFF" class="h-10 w-12 bg-transparent border border-border rounded cursor-pointer" />
                  <input id="color-bg-hex" type="text" value="#FFFFFF" class="flex-1 px-3 py-2 bg-bg border border-border rounded-lg text-text text-sm font-mono focus:outline-none focus:border-accent" />
                </div>
              </div>
            </div>

            <div class="grid grid-cols-3 gap-4 mb-4">
              <div>
                <label class="block text-sm font-medium text-muted mb-2">Dot Style</label>
                <select id="style-dot" class="w-full px-3 py-2 bg-bg border border-border rounded-lg text-text text-sm focus:outline-none focus:border-accent">
                  <option value="square">Square</option>
                  <option value="rounded" selected>Rounded</option>
                  <option value="dots">Dots</option>
                  <option value="classy">Classy</option>
                  <option value="classy-rounded">Classy Rounded</option>
                  <option value="extra-rounded">Extra Rounded</option>
                </select>
              </div>
              <div>
                <label class="block text-sm font-medium text-muted mb-2">Corner Square</label>
                <select id="style-cs" class="w-full px-3 py-2 bg-bg border border-border rounded-lg text-text text-sm focus:outline-none focus:border-accent">
                  <option value="square">Square</option>
                  <option value="dot">Dot</option>
                  <option value="extra-rounded" selected>Extra Rounded</option>
                </select>
              </div>
              <div>
                <label class="block text-sm font-medium text-muted mb-2">Corner Dot</label>
                <select id="style-cd" class="w-full px-3 py-2 bg-bg border border-border rounded-lg text-text text-sm focus:outline-none focus:border-accent">
                  <option value="square">Square</option>
                  <option value="dot" selected>Dot</option>
                </select>
              </div>
            </div>

            <!-- NEW: Size Control with Presets and Custom Input -->
            <div class="mb-4">
              <label class="block text-sm font-medium text-muted mb-2">Size (px)</label>
              <div class="flex gap-2 mb-2">
                <button type="button" onclick="setQrSize(300, this)" class="size-preset flex-1 px-3 py-2 bg-accent text-bg border border-accent rounded-lg text-sm font-semibold transition-colors">300px</button>
                <button type="button" onclick="setQrSize(500, this)" class="size-preset flex-1 px-3 py-2 bg-bg border border-border text-text hover:border-accent rounded-lg text-sm font-semibold transition-colors">500px</button>
                <button type="button" onclick="enableCustomSize(this)" class="size-preset flex-1 px-3 py-2 bg-bg border border-border text-text hover:border-accent rounded-lg text-sm font-semibold transition-colors">Custom</button>
              </div>
              <input id="custom-size-input" type="number" min="150" max="1000" value="300" class="hidden w-full px-3 py-2 bg-bg border border-border rounded-lg text-text text-sm font-mono focus:outline-none focus:border-accent" />
            </div>

            <div>
              <label class="block text-sm font-medium text-muted mb-2">Center Logo (Optional)</label>
              <input id="logo-upload" type="file" accept="image/*" class="w-full text-sm text-muted file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-semibold file:bg-accent/10 file:text-accent hover:file:bg-accent/20 cursor-pointer" />
              <button id="remove-logo" class="mt-2 text-xs text-red-400 hover:text-red-300 hidden">Remove Logo</button>
            </div>
          </div>
        </div>

        <!-- Right Column: Download & Preview (2/5 width) -->
        <div class="lg:col-span-2 space-y-6">
          <div class="glass-card rounded-2xl p-6 md:p-8 border border-border reveal flex flex-col items-center">
            <h2 class="text-lg font-bold text-text mb-6 w-full text-center">Download & Preview</h2>
               <!-- NEW: Force Canvas Sync Button -->
   <button id="force-update-btn" class="w-full px-4 py-3 bg-gradient-to-r from-accent to-accent2 text-bg font-bold rounded-lg hover:opacity-90 transition-all flex items-center justify-center gap-2 mb-4">
     <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path></svg>
     Apply Changes & Sync Canvas
   </button>
            <!-- Download Buttons MOVED TO TOP -->
            <div class="w-full grid grid-cols-2 gap-3 mb-8">
              <button onclick="downloadQR('png')" class="px-4 py-3 bg-accent text-bg font-bold rounded-lg hover:bg-accent2 transition-all flex items-center justify-center gap-2">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path></svg>
                PNG
              </button>
              <button onclick="downloadQR('jpeg')" class="px-4 py-3 bg-bg border border-border text-text font-bold rounded-lg hover:border-accent hover:text-accent transition-all flex items-center justify-center gap-2">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path></svg>
                JPEG
              </button>
              <button onclick="downloadQR('svg')" class="px-4 py-3 bg-bg border border-border text-text font-bold rounded-lg hover:border-accent hover:text-accent transition-all flex items-center justify-center gap-2">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path></svg>
                SVG
              </button>
              <button onclick="downloadQR('webp')" class="px-4 py-3 bg-bg border border-border text-text font-bold rounded-lg hover:border-accent hover:text-accent transition-all flex items-center justify-center gap-2">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path></svg>
                WEBP
              </button>
            </div>

            <!-- Preview Container MOVED TO BOTTOM (No sticky, no overlap) -->
            <div id="qr-container" class="bg-white p-4 rounded-xl shadow-2xl shadow-black/20 flex items-center justify-center w-full mx-auto overflow-hidden">
              <!-- QR Code renders here -->
            </div>
          </div>
        </div>

      </div>
    </div>
  </main>
    <script>
    import QRCodeStyling from 'qr-code-styling';

    // 1. Initialize QR Code
    const qrCode = new QRCodeStyling({
      width: 300,
      height: 300,
      type: "canvas", // Changed to canvas for better PNG/JPEG export stability
      data: "WIFI:T:WPA;S:MyWifi;P:password123;H:false;;",
      image: "",
      dotsOptions: { color: "#0A0178", type: "rounded" },
      backgroundOptions: { color: "#FFFFFF" },
      cornersSquareOptions: { type: "extra-rounded" },
      cornersDotOptions: { type: "dot" },
      imageOptions: { crossOrigin: "anonymous", margin: 10, imageSize: 0.4 }
    });

    const container = document.getElementById('qr-container');
    qrCode.append(container);

    // 2. State Management
    let currentType = 'wifi';
    let logoBase64 = "";
    let currentSize = 300;

    // 3. Helper: Get Data String based on Type
    function getDataString() {
      if (currentType === 'wifi') {
        const ssid = document.getElementById('wifi-ssid').value || 'MyWifi';
        const pass = document.getElementById('wifi-pass').value || '';
        const enc = document.getElementById('wifi-enc').value;
        const hidden = document.getElementById('wifi-hidden').checked;
        return `WIFI:T:${enc};S:${ssid};P:${pass};H:${hidden};;`;
      } else if (currentType === 'url') {
        return document.getElementById('url-val').value || 'https://zxsprd.com';
      } else if (currentType === 'text') {
        return document.getElementById('text-val').value || 'Hello World';
      } else if (currentType === 'email') {
        const email = document.getElementById('email-addr').value || 'info@example.com';
        const sub = document.getElementById('email-sub').value;
        const body = document.getElementById('email-body').value;
        return `mailto:${email}?subject=${encodeURIComponent(sub)}&body=${encodeURIComponent(body)}`;
      } else if (currentType === 'phone') {
        return `tel:${document.getElementById('phone-val').value || '+1234567890'}`;
      }
    }

    // 4. Get Current Settings Object
    function getCurrentSettings() {
      return {
        data: getDataString(),
        width: currentSize,
        height: currentSize,
        image: logoBase64,
        dotsOptions: { 
          color: document.getElementById('color-fg').value, 
          type: document.getElementById('style-dot').value 
        },
        backgroundOptions: { color: document.getElementById('color-bg').value },
        cornersSquareOptions: { type: document.getElementById('style-cs').value },
        cornersDotOptions: { type: document.getElementById('style-cd').value }
      };
    }

    // 5. Update QR Function (For Live Preview)
    function updateQR() {
      qrCode.update(getCurrentSettings());
    }

    // 6. THE NUCLEAR FIX: Force Canvas Sync Button
    document.getElementById('force-update-btn').addEventListener('click', async () => {
      const btn = document.getElementById('force-update-btn');
      const originalHTML = btn.innerHTML;
      
      btn.innerHTML = `<svg class="w-5 h-5 animate-spin" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg> Syncing Canvas...`;
      btn.disabled = true;

      // NUCLEAR TRICK: Clear the container completely to destroy the old cached canvas
      container.innerHTML = '';
      
      // Re-append a fresh instance
      qrCode.append(container);
      
      // Apply the latest settings
      await qrCode.update(getCurrentSettings());

      // Wait a split second for the browser to paint
      await new Promise(r => setTimeout(r, 300));

      btn.innerHTML = `<svg class="w-5 h-5 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> Canvas Synced!`;
      
      setTimeout(() => {
        btn.innerHTML = originalHTML;
        btn.disabled = false;
      }, 1500);
    });

    // 7. Size Control Logic
    window.setQrSize = (size, btn) => {
      currentSize = size;
      document.getElementById('custom-size-input').classList.add('hidden');
      
      document.querySelectorAll('.size-preset').forEach(b => {
        b.classList.remove('bg-accent', 'text-bg', 'border-accent');
        b.classList.add('bg-bg', 'border-border', 'text-text');
      });
      btn.classList.remove('bg-bg', 'border-border', 'text-text');
      btn.classList.add('bg-accent', 'text-bg', 'border-accent');
      
      updateQR();
    };

    window.enableCustomSize = (btn) => {
      document.getElementById('custom-size-input').classList.remove('hidden');
      document.querySelectorAll('.size-preset').forEach(b => {
        b.classList.remove('bg-accent', 'text-bg', 'border-accent');
        b.classList.add('bg-bg', 'border-border', 'text-text');
      });
      btn.classList.remove('bg-bg', 'border-border', 'text-text');
      btn.classList.add('bg-accent', 'text-bg', 'border-accent');
    };

    document.getElementById('custom-size-input').addEventListener('input', (e) => {
      let val = parseInt(e.target.value);
      if(val >= 150 && val <= 1000) {
        currentSize = val;
        updateQR();
      }
    });

    // 8. Tab Switching Logic
    document.querySelectorAll('.tab-btn').forEach(btn => {
      btn.addEventListener('click', (e) => {
        document.querySelectorAll('.tab-btn').forEach(b => {
          b.classList.remove('bg-accent', 'text-bg');
          b.classList.add('bg-bg', 'border', 'border-border', 'text-text');
        });
        e.target.classList.remove('bg-bg', 'border', 'border-border', 'text-text');
        e.target.classList.add('bg-accent', 'text-bg');

        currentType = e.target.dataset.type;
        document.querySelectorAll('.form-panel').forEach(p => p.classList.add('hidden'));
        document.getElementById(`form-${currentType}`).classList.remove('hidden');
        updateQR();
      });
    });

    // 9. Sync Color Pickers and Hex Inputs
    ['fg', 'bg'].forEach(type => {
      const colorInput = document.getElementById(`color-${type}`);
      const hexInput = document.getElementById(`color-${type}-hex`);
      
      colorInput.addEventListener('input', (e) => { hexInput.value = e.target.value; updateQR(); });
      hexInput.addEventListener('input', (e) => { 
        if(/^#[0-9A-F]{6}$/i.test(e.target.value)) { colorInput.value = e.target.value; updateQR(); }
      });
    });

    // 10. Attach Listeners to all inputs
    document.querySelectorAll('input, select, textarea').forEach(el => {
      if(el.id !== 'logo-upload' && el.id !== 'custom-size-input') {
        el.addEventListener('input', updateQR);
        el.addEventListener('change', updateQR);
      }
    });

    // 11. Logo Upload Logic
    document.getElementById('logo-upload').addEventListener('change', (e) => {
      const file = e.target.files[0];
      if (file) {
        const reader = new FileReader();
        reader.onload = () => {
          logoBase64 = reader.result;
          document.getElementById('remove-logo').classList.remove('hidden');
          updateQR();
        };
        reader.readAsDataURL(file);
      }
    });

    document.getElementById('remove-logo').addEventListener('click', () => {
      logoBase64 = "";
      document.getElementById('logo-upload').value = "";
      document.getElementById('remove-logo').classList.add('hidden');
      updateQR();
    });

    // 12. Download Logic (Now 100% reliable because canvas is synced)
    window.downloadQR = (format) => {
      qrCode.download({ name: "zx-labs-qr", extension: format });
    };
  </script>
</Layout>