---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';

const tools = [
{
  name: "Kinetic Particles",
  icon: "",
  desc: "An interactive, high-performance canvas physics playground driven by real-time cursor velocities.",
  href: "/playground/interactive-mouse/",
  tags: ["Canvas", "Physics", "Creative-Coding"]
},
{
  name: "Pixel Exploder",
  icon: "",
  desc: "A multi-layered interactive playground which tears webcam images into thousands of floating spring-vector particles.",
  href: "/playground/webcam-exploder/",
  tags: ["Webcam", "Interactive", "Canvas"]
},

{
  name: "Elastic Distorter",
  icon: "",
  desc: "An interactive digital funhouse mirror using webcam slice matrices and spring equations to warp stream frames.",
  href: "/playground/face-distorter/",
  tags: ["Kids", "Webcam", "Mesh-Warp"]
},

{
  name: "Sensory Playground",
  icon: "",
  desc: "A premium multi-touch sensory sandbox for early childhood exploration combining physics, sound synthesis, and fluid interaction.",
  href: "/playground/premium-kids-sandbox/",
  tags: ["Kids", "Audio-Reactive", "Physics", "Premium"]
},

{
  name: "Magical Painter",
  icon: "",
  desc: "A sensory drawing playground for kids utilizing multi-touch color tracking and generative popping bubble physics.",
  href: "/playground/rainbow-painter/",
  tags: ["Kids", "Sensory", "Canvas"]
},
{
  name: "Elastic Mesh",
  icon: "",
  desc: "A multi-touch grid matrix simulation reacting directly to complex swipe forces and spring vectors.",
  href: "/playground/interactive-touch/",
  tags: ["Touch", "Mobile-Ready", "Physics"]
},
{
  name: "Chrono Glow Clock",
  icon: "",
  desc: "A minimal full-viewport digital and analog studio clock featuring interactive custom lighting controls.",
  href: "/playground/interactive-clock/",
  tags: ["Utility", "UI-Design", "Customizable"]
},
{
  name: "Frequency Mesh",
  icon: "",
  desc: "A full-screen microphone-driven vector mesh that transforms frequency inputs into dynamic audio wave deformulations.",
  href: "/playground/realtime-mesh/",
  tags: ["AV", "Audio-Reactive", "Canvas"]
}
,

  {
    name: "IP Subnet Calculator",
    icon: "",
    desc: "Calculate network ranges, broadcast addresses, and usable hosts for IPv4 CIDR blocks.",
    href: "/playground/subnet-calculator/",
    tags: ["Networking", "IPv4", "CIDR"]
  },
  {
    name: "Calculator & Unit Converter",
    icon: "",
    desc: "Perform calculations and convert between IT units (Bytes, KB, MB, GB, TB) and more.",
    href: "/playground/calculator/",
    tags: ["Utility", "Conversion", "Math"]
  },
  {
  name: "IT Network Toolkit",
  icon: "",
  desc: "A clean developer toolkit running browser-native network diagnostics, DNS-over-HTTPS lookup lookups, and Geolocation tasks.",
  href: "/playground/it-toolkit/",
  tags: ["DevOps", "Utility", "API-Integration"]
},
 {
    name: "Universal QR Studio",
    icon: "📱",
    desc: "Generate highly customized QR codes for Wi-Fi, URLs, Text, and more. Add logos, change colors, and export in multiple formats.",
    href: "/playground/qr-generator/",
    tags: ["Utility", "Design", "Wi-Fi"]
  },

  {
    name: "Linux Command Studio",
    icon: "🐧",
    desc: "Interactive command builder and smart reference for IT Admins. Supports Ubuntu, Oracle Linux, and more.",
    href: "/playground/linux-studio/",
    tags: ["Linux", "Terminal", "IT Admin"]
  },
  
    {
    name: "Global Latency Mapper",
    icon: "🌍",
    desc: "Advanced network diagnostics. Measure real-world latency, jitter, and packet loss to global edge nodes to prove routing issues.",
    href: "/playground/latency-mapper/",
    tags: ["Networking", "Diagnostics", "IT Admin"]
  },
    {
    name: "CVSS v3.1 Calculator",
    icon: "🛡️",
    desc: "Interactive vulnerability severity calculator. Calculate Base Scores and generate official Vector Strings in real-time.",
    href: "/playground/cvss-calculator/",
    tags: ["GRC", "Cybersecurity", "Vulnerability"]
  },
    {
    name: "STRIDE Threat Modeler",
    icon: "🛡️",
    desc: "Identify and mitigate AppSec threats using Microsoft's STRIDE methodology. Build and export your Threat Matrix to CSV.",
    href: "/playground/stride-modeler/",
    tags: ["AppSec", "GRC", "Threat Modeling"]
  },
    {
    name: "NIST CSF Gap Analyzer",
    icon: "🕸️",
    desc: "Assess your cybersecurity maturity across the 5 NIST core functions. Visualize gaps with a real-time radar chart.",
    href: "/playground/nist-gap-analyzer/",
    tags: ["GRC", "Compliance", "NIST"]
  },
  
    {
    name: "Password Entropy Analyzer",
    icon: "🔐",
    desc: "Calculate Shannon Entropy, estimate GPU crack times, and detect bad patterns like leet speak and keyboard walks.",
    href: "/playground/password-analyzer/",
    tags: ["Cybersecurity", "Cryptography", "Identity"]
  },
    {
    name: "IR Playbook Generator",
    icon: "🚨",
    desc: "Generate a comprehensive, NIST-aligned Incident Response Plan. Fill in your details and export a ready-to-use Markdown playbook.",
    href: "/playground/ir-playbook-generator/",
    tags: ["GRC", "Incident Response", "SOC"]
  },
    {
    name: "Zero Trust Architecture Visualizer",
    icon: "️",
    desc: "Design, visualize, and simulate Zero Trust networks. Define entities, map policies, and run real-time traffic evaluations.",
    href: "/playground/zta-visualizer/",
    tags: ["Cybersecurity", "Architecture", "Enterprise"]
  }
  
  
];
---

<Layout title="ZX Labs | Interactive Tools" lang="en" dir="ltr">
  <Navbar currentLang="en" />

  <main class="min-h-screen pt-24 px-6 pb-20">
    <div class="max-w-6xl mx-auto">
      
      <!-- Header -->
      <div class="text-center mb-16 reveal">
        <h1 class="text-4xl md:text-6xl font-bold text-text mb-6">
          ZX <span class="text-transparent bg-clip-text bg-gradient-to-r from-accent to-accent2">Labs</span>
        </h1>
        <p class="text-muted text-xl max-w-2xl mx-auto">
          A collection of interactive tools and experiments built for the curious mind. 
          Explore, calculate, and discover.
        </p>
        <div class="w-32 h-1 bg-gradient-to-r from-accent to-accent2 mx-auto mt-8 rounded-full"></div>
      </div>

      <!-- Tools Grid -->
      <div class="grid md:grid-cols-2 gap-8">
        {tools.map((tool) => (
          <a 
            href={tool.href}
            class="group glass-card glow-card rounded-2xl p-8 border border-border hover:border-accent/50 transition-all duration-300 block reveal"
          >
            <div class="text-5xl mb-6">{tool.icon}</div>
            <h2 class="text-2xl font-bold text-text mb-3 group-hover:text-accent transition-colors">
              {tool.name}
            </h2>
            <p class="text-muted mb-6 leading-relaxed">
              {tool.desc}
            </p>
            <div class="flex flex-wrap gap-2 mb-6">
              {tool.tags.map((tag) => (
                <span class="px-3 py-1 text-xs bg-accent/10 text-accent border border-accent/20 rounded-full">
                  {tag}
                </span>
              ))}
            </div>
            <div class="flex items-center gap-2 text-accent font-semibold group-hover:gap-4 transition-all">
              Launch Tool 
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
              </svg>
            </div>
          </a>
        ))}
      </div>

      <!-- Coming Soon Section -->
      <div class="mt-16 text-center reveal">
        <p class="text-muted text-sm mb-4">More tools coming soon...</p>
        <div class="flex justify-center gap-2">
          <span class="w-2 h-2 bg-accent rounded-full animate-pulse"></span>
          <span class="w-2 h-2 bg-accent rounded-full animate-pulse animation-delay-100"></span>
          <span class="w-2 h-2 bg-accent rounded-full animate-pulse animation-delay-200"></span>
        </div>
      </div>

    </div>
  </main>
</Layout>