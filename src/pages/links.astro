---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import linksData from '../data/links.json';
---

<Layout title="Links | Zeeshan Haider" lang="en" dir="ltr">
  <Navbar currentLang="en" />

  <main class="min-h-screen pt-24 px-6 pb-20">
    <div class="max-w-3xl mx-auto">
      <!-- Page Header -->
      <div class="text-center mb-12">
        <h1 class="text-4xl md:text-5xl font-bold mb-4 text-text">
          Quick <span class="text-transparent bg-clip-text bg-gradient-to-r from-accent to-accent2">Links</span>
        </h1>
        <p class="text-muted text-lg">Access my resumes, portfolios, and social channels in one place.</p>
      </div>

      <!-- Links Categories -->
      <div class="space-y-12">
        {linksData.map((section) => (
          <div class="bg-card rounded-2xl border border-border p-6 md:p-8">
            <!-- Category Title -->
            <h2 class="text-2xl font-bold text-accent mb-6 flex items-center gap-2">
              <span class="w-2 h-8 bg-accent rounded-full"></span>
              {section.category}
            </h2>

            <!-- Links Grid -->
            <div class="grid gap-4">
              {section.items.map((item) => (
                <a 
                  href={item.url} 
                  target="_blank" 
                  rel="noopener noreferrer"
                  class="group flex items-center justify-between p-4 rounded-xl bg-bg border border-border hover:border-accent/50 hover:bg-accent/5 transition-all duration-300"
                >
                  <span class="text-text font-medium group-hover:text-accent transition-colors">
                    {item.label}
                  </span>
                  
                  <!-- Button / Icon -->
                  <span class="flex items-center gap-2 px-4 py-2 text-sm font-semibold text-accent bg-accent/10 rounded-lg group-hover:bg-accent group-hover:text-bg transition-all duration-300">
                    {item.type === 'download' ? 'Download Now' : 'Open'}
                    <svg class="w-4 h-4 group-hover:translate-x-1 group-hover:-translate-y-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
                    </svg>
                  </span>
                </a>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </main>

  <footer class="py-8 text-center text-muted text-sm border-t border-border">
    <p>&copy; {new Date().getFullYear()} Zeeshan Haider. All rights reserved.</p>
  </footer>
</Layout>