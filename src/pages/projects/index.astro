---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import { getCollection } from 'astro:content';

// Fetch all projects, sorted by year (newest first)
const projects = await getCollection('projects');
const sortedProjects = projects.sort((a, b) => {
  const yearA = parseInt(a.data.year) || 0;
  const yearB = parseInt(b.data.year) || 0;
  return yearB - yearA;
});
---

<Layout title="Projects | Zeeshan Haider" lang="en" dir="ltr">
  <Navbar currentLang="en" />

  <main class="min-h-screen pt-24 px-6 pb-20">
    <div class="max-w-6xl mx-auto">
      <!-- Page Header -->
      <div class="text-center mb-16">
        <h1 class="text-4xl md:text-5xl font-bold mb-4 text-text">
          Featured <span class="text-transparent bg-clip-text bg-gradient-to-r from-accent to-accent2">Projects</span>
        </h1>
        <p class="text-muted text-lg">Showcasing my work in cybersecurity, engineering, and technology.</p>
      </div>

      <!-- Projects Grid -->
      {sortedProjects.length > 0 ? (
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          {sortedProjects.map((project) => {
            const { data, slug } = project;
            return (
              <a href={`/projects/${slug}/`} class="group relative overflow-hidden rounded-xl bg-card border border-border hover:border-accent/50 transition-all duration-300 hover:-translate-y-2 block">
                {data.image && (
                  <div class="aspect-video overflow-hidden bg-bg">
                    <img 
                      src={data.image} 
                      alt={data.title}
                      class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
                    />
                  </div>
                )}
                <div class="p-6">
                  <div class="flex items-center gap-2 mb-3">
                    <span class="text-xs text-accent font-mono">{data.year || 'N/A'}</span>
                    <span class="text-xs text-muted">•</span>
                    <span class="text-xs text-muted">{data.client || 'Personal'}</span>
                  </div>
                  <h3 class="text-xl font-bold text-text mb-3 group-hover:text-accent transition-colors">
                    {data.title}
                  </h3>
                  <p class="text-muted text-sm leading-relaxed mb-4">
                    {data.excerpt || 'Click to view project details...'}
                  </p>
                  {data.tech && data.tech.length > 0 && (
                    <div class="flex flex-wrap gap-2">
                      {data.tech.slice(0, 3).map((tech) => (
                        <span class="px-2 py-1 text-xs bg-bg text-accent rounded border border-border">
                          {tech}
                        </span>
                      ))}
                    </div>
                  )}
                </div>
              </a>
            );
          })}
        </div>
      ) : (
        <div class="text-center py-20 bg-card rounded-xl border border-border border-dashed">
          <p class="text-muted text-lg">No projects to showcase yet. Check back soon!</p>
        </div>
      )}
    </div>
  </main>

  <footer class="py-8 text-center text-muted text-sm border-t border-border">
    <p>&copy; {new Date().getFullYear()} Zeeshan Haider. All rights reserved.</p>
  </footer>
</Layout>