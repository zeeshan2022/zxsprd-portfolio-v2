---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
---

<Layout title="Terms of Service | Zeeshan Haider" lang="en" dir="ltr">
  <Navbar currentLang="en" />

  <main class="min-h-screen pt-24 px-6 pb-20">
    <div class="max-w-3xl mx-auto">
      
      <!-- Header -->
      <div class="text-center mb-12 reveal">
        <h1 class="text-4xl md:text-5xl font-bold text-text mb-4">
          Terms of <span class="text-transparent bg-clip-text bg-gradient-to-r from-accent to-accent2">Service</span>
