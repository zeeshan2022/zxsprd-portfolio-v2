---
// 1. Import ALL language files
import enData from '../data/en/data.json';
import arData from '../data/ar/data.json';
import zhData from '../data/zh/data.json';
import frData from '../data/fr/data.json';
import urData from '../data/ur/data.json'
import psData from '../data/ps/data.json';


// 2. Create a map of all supported languages
const allLanguages = {
  en: enData,
  ar: arData,
  zh: zhData,
  fr: frData,
  ur: urData,
  ps: psData, 
};

// 3. Detect language from URL (e.g., '/ar/' becomes 'ar', '/zh/' becomes 'zh')
const currentLang = Astro.url.pathname.split('/')[1] || 'en';

// 4. Load the correct data, defaulting to English if the language isn't found
const data = allLanguages[currentLang] || enData;


  const { experience, sections } = data;
---

<section id="experience" class="py-20 px-6 bg-bg-2/30">
  <div class="max-w-4xl mx-auto reveal">
    <h2 class="text-3xl font-bold mb-10 flex items-center gap-3">
      <span class="w-3 h-3 rounded-full bg-accent shadow-[0_0_10px_#00e0b8]"></span>
        {sections.experience}
    </h2>
    <div class="relative border-l-2 border-dashed border-border pl-8 space-y-12">
      {experience.map((job) => (
        <div class="relative">
          <div class="absolute -left-[41px] top-1 w-4 h-4 rounded-full bg-accent shadow-[0_0_10px_#00e0b8]"></div>
          <h3 class="text-xl font-bold text-text">{job.role}</h3>
          <p class="text-accent2 font-semibold mt-1">{job.company} | {job.location}</p>
          <p class="text-muted text-sm mb-4">{job.period}</p>
          <ul class="space-y-2">
            {job.achievements.map((achievement) => (
              <li class="text-muted flex items-start gap-2">
                <span class="text-accent mt-1">▹</span>
                <span>{achievement}</span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>