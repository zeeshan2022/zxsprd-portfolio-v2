---
import data from '../data/en/data.json';
const { hero } = data;
---

<section id="contact" class="py-20 px-6 bg-bg-2/30">
  <div class="max-w-4xl mx-auto text-center">
    <h2 class="text-3xl font-bold mb-4 flex items-center justify-center gap-3">
      <span class="w-3 h-3 rounded-full bg-accent shadow-[0_0_10px_#00e0b8]"></span>
      Get in Touch
    </h2>
    <p class="text-muted text-lg mb-10">Based in Dubai, UAE — open to cybersecurity, research, and consulting opportunities.</p>
    
    <div class="grid md:grid-cols-3 gap-6 mb-12">
      <a href={`mailto:${hero.email}`} class="p-6 rounded-xl bg-card border border-border hover:border-accent transition-all hover:-translate-y-1">
        <div class="text-3xl mb-3">✉️</div>
        <p class="text-muted text-sm">Email</p>
        <p class="text-text font-semibold break-all">{hero.email}</p>
      </a>
      <a href={`tel:${hero.phone}`} class="p-6 rounded-xl bg-card border border-border hover:border-accent transition-all hover:-translate-y-1">
        <div class="text-3xl mb-3">📞</div>
        <p class="text-muted text-sm">Phone</p>
        <p class="text-text font-semibold">{hero.phone}</p>
      </a>
      <a href={hero.linkedin} target="_blank" class="p-6 rounded-xl bg-card border border-border hover:border-accent transition-all hover:-translate-y-1">
        <div class="text-3xl mb-3">💼</div>
        <p class="text-muted text-sm">LinkedIn</p>
        <p class="text-text font-semibold">Connect with me</p>
      </a>
    </div>

    <!-- Netlify Contact Form -->
    <form name="contact" method="POST" data-netlify="true" class="max-w-2xl mx-auto text-left space-y-4">
      <input type="hidden" name="form-name" value="contact" />
      <div>
        <label class="block text-muted text-sm mb-2">Name</label>
        <input type="text" name="name" required class="w-full p-3 rounded-lg bg-card border border-border text-text focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-muted text-sm mb-2">Email</label>
        <input type="email" name="email" required class="w-full p-3 rounded-lg bg-card border border-border text-text focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-muted text-sm mb-2">Message</label>
        <textarea name="message" rows="5" required class="w-full p-3 rounded-lg bg-card border border-border text-text focus:border-accent focus:outline-none transition-colors resize-none"></textarea>
      </div>
      <button type="submit" class="w-full py-3 rounded-lg bg-gradient-to-r from-accent to-accent2 text-bg font-bold hover:shadow-[0_0_20px_rgba(0,224,184,0.4)] transition-all duration-300 hover:-translate-y-1">
        Send Message
      </button>
    </form>
  </div>
</section>