---
// 1. Import ALL language files
import enData from '../data/en/data.json';
import arData from '../data/ar/data.json';
import zhData from '../data/zh/data.json';
import frData from '../data/fr/data.json';
import urData from '../data/ur/data.json'
import psData from '../data/ps/data.json';


// 2. Create a map of all supported languages
const allLanguages = {
  en: enData,
  ar: arData,
  zh: zhData,
  fr: frData,
   ur: urData,
   ps: psData, 
};

// 3. Detect language from URL (e.g., '/ar/' becomes 'ar', '/zh/' becomes 'zh')
const currentLang = Astro.url.pathname.split('/')[1] || 'en';

// 4. Load the correct data, defaulting to English if the language isn't found
const data = allLanguages[currentLang] || enData;



const { hero, about } = data;
---




<!-- Hero Section -->
<!-- Hero Section with Continuous Cyber Graphic -->
<!-- Hero Section with Continuous Cyber Graphic -->
<header class="relative min-h-screen flex items-center justify-center pt-20 px-6 overflow-hidden">
  
  <!-- CONTINUOUS GRAPHIC: Animated Background -->
  <div class="absolute inset-0 z-0">
    <!-- Base Gradient -->
    <div class="absolute inset-0 bg-gradient-to-br from-bg via-bg to-accent/10"></div>
    
    <!-- Floating Glowing Orbs (Using standard Tailwind animate-pulse) -->
    <div class="absolute top-1/4 start-1/4 w-72 h-72 bg-accent/20 rounded-full blur-3xl animate-pulse"></div>
    <div class="absolute bottom-1/4 end-1/4 w-72 h-72 bg-purple-500/20 rounded-full blur-3xl animate-pulse"></div>
  </div>

  <!-- Hero Content -->
  <div class="relative z-10 max-w-4xl mx-auto text-center">
    <div class="reveal">
      <p class="text-accent font-mono text-sm md:text-base mb-4 tracking-widest uppercase">
        {hero.location}
      </p>
      <h1 class="text-4xl md:text-6xl lg:text-7xl font-bold text-text mb-6 leading-tight">
        {hero.name}
      </h1>
      <h2 class="text-xl md:text-2xl text-muted mb-8 font-light">
        {hero.title}
      </h2>
      
      <!-- CTA Buttons -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mt-10">
        <a href="/#contact" class="px-8 py-3 bg-accent text-bg font-bold rounded-lg hover:bg-accent2 transition-all duration-300 hover:scale-105 shadow-lg shadow-accent/20">
          {hero.cta_primary}
        </a>
        <a href={hero.cta_secondary_link || '/ZeeshanHaider_CV_SecurityManager.pdf'} target="_blank" class="px-8 py-3 bg-transparent border border-border text-text font-bold rounded-lg hover:border-accent hover:text-accent transition-all duration-300 hover:scale-105">
          {hero.cta_secondary}
        </a>
      </div>
    </div>
  </div>

  <!-- Scroll Down Indicator -->
  <div class="absolute bottom-10 start-1/2 -translate-x-1/2 animate-bounce text-muted">
    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
    </svg>
  </div>
</header>

<!-- About Section -->
<section id="about" class="py-20 px-6 bg-bg-2/30">
  <div class="max-w-4xl mx-auto reveal">
    <h2 class="text-3xl font-bold mb-6 flex items-center gap-3">
      <span class="w-3 h-3 rounded-full bg-accent shadow-[0_0_10px_#00e0b8]"></span>
      {about.title}
    </h2>
    <p class="text-muted text-lg leading-relaxed">
      {about.summary}
    </p>
  </div>
</section>

<!-- Modular Sections -->
<slot />

<!-- Footer -->
<footer class="py-8 text-center text-muted text-sm border-t border-border">
  <p>&copy; {new Date().getFullYear()} Zeeshan Haider. All rights reserved.</p>
</footer>