---
// 1. Import ALL language files
import enData from '../data/en/data.json';
import arData from '../data/ar/data.json';
import zhData from '../data/zh/data.json';
import frData from '../data/fr/data.json';
import urData from '../data/ur/data.json'
import psData from '../data/ps/data.json';


// 2. Create a map of all supported languages
const allLanguages = {
  en: enData,
  ar: arData,
  zh: zhData,
  fr: frData,
   ur: urData,
   ps: psData, 
};

// 3. Detect language from URL (e.g., '/ar/' becomes 'ar', '/zh/' becomes 'zh')
const currentLang = Astro.url.pathname.split('/')[1] || 'en';

// 4. Load the correct data, defaulting to English if the language isn't found
const data = allLanguages[currentLang] || enData;



const { hero, about } = data;
---




<!-- Hero Section -->
<header class="min-h-screen flex items-center justify-center pt-20 px-6">
  <div class="max-w-4xl mx-auto text-center">
    <div class="w-24 h-24 mx-auto mb-6 rounded-full bg-gradient-to-br from-accent to-accent2 flex items-center justify-center text-bg text-3xl font-extrabold shadow-[0_0_30px_rgba(0,224,184,0.3)]">
      {hero.name.split(' ').map(n => n[0]).join('')}
    </div>
    <h1 class="text-4xl md:text-6xl font-bold mb-4 text-text">
      {hero.name.split(' ')[0]} <span class="text-transparent bg-clip-text bg-gradient-to-r from-accent to-accent2">{hero.name.split(' ')[1]}</span>
    </h1>
    <p class="text-xl md:text-2xl text-muted mb-2">{hero.title}</p>
    <p class="text-sm text-muted mb-8 flex items-center justify-center gap-2">
      <span>📍</span> {hero.location}
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a href="#contact" class="px-8 py-3 rounded-lg bg-gradient-to-r from-accent to-accent2 text-bg font-bold hover:shadow-[0_0_20px_rgba(0,224,184,0.4)] transition-all duration-300 hover:-translate-y-1">
        {hero.cta_primary}
      </a>
      <a href="/ZeeshanHaider_CV_SecurityManager.pdf" target="_blank" class="px-8 py-3 rounded-lg border border-border text-text font-semibold hover:border-accent hover:text-accent transition-all duration-300">
        {hero.cta_secondary}
      </a>
    </div>
  </div>
</header>

<!-- About Section -->
<section id="about" class="py-20 px-6 bg-bg-2/30">
  <div class="max-w-4xl mx-auto">
    <h2 class="text-3xl font-bold mb-6 flex items-center gap-3">
      <span class="w-3 h-3 rounded-full bg-accent shadow-[0_0_10px_#00e0b8]"></span>
      {about.title}
    </h2>
    <p class="text-muted text-lg leading-relaxed">
      {about.summary}
    </p>
  </div>
</section>

<!-- Modular Sections -->
<slot />

<!-- Footer -->
<footer class="py-8 text-center text-muted text-sm border-t border-border">
  <p>&copy; {new Date().getFullYear()} Zeeshan Haider. All rights reserved.</p>
</footer>