---
interface Props {
  currentLang: 'en' | 'ar' | 'zh' | 'fr' | 'ur' | 'ps';
}

const { currentLang } = Astro.props;

// 1. Rearranged Menu Order
const menuLinks = [
  { href: '/', label: 'Home' },
  { href: '/#contact', label: 'Contact' },
  { href: '/links/', label: 'Links' },
  { href: '/blog/', label: 'Blog' },
  { href: '/projects/', label: 'Projects' },
];

// 2. All 6 Languages for the Dropdown
const languages = [
  { code: 'en', label: 'English', flag: '🇬🇧' },
  { code: 'ar', label: 'العربية', flag: '🇦🇪' },
  { code: 'zh', label: '中文', flag: '🇨🇳' },
  { code: 'fr', label: 'Français', flag: '🇫🇷' },
  { code: 'ur', label: 'اردو', flag: '🇵🇰' },
  { code: 'ps', label: 'پښتو', flag: '🇦🇫' },
];

// Find current language details
const currentLangData = languages.find(l => l.code === currentLang) || languages[0];
---

<nav transition:name="navbar" class="fixed top-0 start-0 end-0 z-50 bg-bg/80 backdrop-blur-md border-b border-border/50">
  <div class="max-w-7xl mx-auto px-6 py-4">
    <div class="flex items-center justify-between">
      
      <!-- Logo -->
      <a href="/" class="text-xl font-bold text-text hover:text-accent transition-colors flex items-center gap-2">
        <span class="w-2 h-2 bg-accent rounded-full animate-pulse"></span>
        Zeeshan Haider
      </a>

      <!-- Desktop View -->
      <div class="hidden md:flex items-center gap-8">
        <!-- Main Menu -->
        <div class="flex items-center gap-6 text-sm font-medium">
          {menuLinks.map((link) => (
            <a 
              href={link.href} 
              class="text-muted hover:text-accent transition-colors duration-200 relative group"
            >
              {link.label}
              <span class="absolute -bottom-1 start-0 w-0 h-0.5 bg-accent transition-all duration-300 group-hover:w-full"></span>
            </a>
          ))}
        </div>

        <!-- Language Dropdown (Globe Icon) -->
        <div class="relative" id="lang-dropdown">
          <button 
            id="lang-btn"
            class="flex items-center gap-2 px-3 py-2 text-sm text-muted hover:text-accent bg-card/50 border border-border rounded-lg hover:border-accent/50 transition-all duration-200"
          >
            <!-- Globe SVG Icon -->
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            <span class="font-medium">{currentLangData.flag} {currentLangData.code.toUpperCase()}</span>
            <svg class="w-3 h-3 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
          </button>

          <!-- Dropdown Menu (RTL Safe using 'start-0') -->
          <div id="lang-menu" class="hidden absolute top-full mt-2 start-0 w-48 bg-card border border-border rounded-xl shadow-2xl shadow-black/20 overflow-hidden z-50">
            {languages.map((lang) => (
              <a 
                href={lang.code === 'en' ? '/' : `/${lang.code}/`}
                class={`flex items-center gap-3 px-4 py-3 text-sm transition-colors ${
                  currentLang === lang.code 
                    ? 'bg-accent/10 text-accent font-bold border-s-2 border-accent' 
                    : 'text-muted hover:bg-bg hover:text-text'
                }`}
              >
                <span class="text-lg">{lang.flag}</span>
                <span>{lang.label}</span>
              </a>
            ))}
          </div>
        </div>
      </div>

      <!-- Mobile Menu Button -->
      <button id="mobile-menu-btn" class="md:hidden text-text hover:text-accent transition-colors">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
    </div>

    <!-- Mobile Menu -->
    <div id="mobile-menu" class="hidden md:hidden mt-4 pb-4 border-t border-border">
      <div class="flex flex-col gap-4 pt-4">
        {menuLinks.map((link) => (
          <a href={link.href} class="text-muted hover:text-accent transition-colors">{link.label}</a>
        ))}
        
        <!-- Mobile Language Grid -->
        <div class="grid grid-cols-2 gap-2 pt-4 border-t border-border">
          {languages.map((lang) => (
            <a 
              href={lang.code === 'en' ? '/' : `/${lang.code}/`}
              class={`flex items-center gap-2 px-3 py-2 text-sm rounded-lg transition-colors ${
                currentLang === lang.code ? 'bg-accent/10 text-accent font-bold' : 'text-muted hover:bg-bg'
              }`}
            >
              <span>{lang.flag}</span>
              <span>{lang.label}</span>
            </a>
          ))}
        </div>
      </div>
    </div>
  </div>
</nav>
<script>
  // 1. Create a function that initializes the navbar interactions
  function initNavbar() {
    // Mobile Menu Toggle
    const mobileBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    mobileBtn?.addEventListener('click', () => mobileMenu?.classList.toggle('hidden'));

    // Language Dropdown Toggle
    const langBtn = document.getElementById('lang-btn');
    const langMenu = document.getElementById('lang-menu');
    
    langBtn?.addEventListener('click', (e) => {
      e.stopPropagation();
      langMenu?.classList.toggle('hidden');
    });
  }

  // 2. Run on initial page load
  initNavbar();

  // 3. CRITICAL: Re-run every time Astro View Transitions swaps the page
  document.addEventListener('astro:page-load', initNavbar);

  // 4. Close dropdown when clicking outside (attached to document once)
  document.addEventListener('click', (e) => {
    const dropdown = document.getElementById('lang-dropdown');
    const langMenu = document.getElementById('lang-menu');
    if (dropdown && langMenu && !dropdown.contains(e.target as Node)) {
      langMenu.classList.add('hidden');
    }
  });
</script>
