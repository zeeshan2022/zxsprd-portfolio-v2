---
import enData from '../data/en/data.json';
import arData from '../data/ar/data.json';
import zhData from '../data/zh/data.json';
import frData from '../data/fr/data.json';
import urData from '../data/ur/data.json';
import psData from '../data/ps/data.json';

const allLanguages = { en: enData, ar: arData, zh: zhData, fr: frData, ur: urData, ps: psData };
const currentLang = Astro.url.pathname.split('/')[1] || 'en';
const data = allLanguages[currentLang] || enData;

const { footer, hero } = data;
const currentYear = new Date().getFullYear();
// Replace {year} placeholder in copyright string
const copyrightText = footer.copyright.replace('{year}', currentYear.toString());

const quickLinks = [
  { label: 'Home', href: '/' },
  { label: 'Blog', href: '/blog/' },
  { label: 'Projects', href: '/projects/' },
  { label: 'Links', href: '/links/' },
];
---

<footer class="relative mt-20 border-t border-border/50 bg-bg/50 backdrop-blur-md">
  <!-- Subtle Top Glow Line -->
  <div class="absolute top-0 start-0 end-0 h-px bg-gradient-to-r from-transparent via-accent/50 to-transparent"></div>

  <div class="max-w-7xl mx-auto px-6 py-12 md:py-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10 md:gap-12">
      
      <!-- Column 1: Brand & Description -->
      <div class="space-y-4">
        <a href="/" class="text-xl font-bold text-text flex items-center gap-2">
          <span class="w-2 h-2 bg-accent rounded-full"></span>
          Zeeshan Haider
        </a>
        <p class="text-muted text-sm leading-relaxed max-w-xs">
          {footer.brand_desc}
        </p>
        <!-- Social Icons (Reusing your existing links) -->
        <div class="flex gap-4 pt-2">
          <a href="https://www.linkedin.com/in/zeeshan2022" target="_blank" class="text-muted hover:text-accent transition-colors">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
          </a>
          <a href="https://github.com/zeeshan2022" target="_blank" class="text-muted hover:text-accent transition-colors">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          </a>
          <a href="mailto:zeeshan.haider28@gmail.com" class="text-muted hover:text-accent transition-colors">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
          </a>
        </div>
      </div>

      <!-- Column 2: Quick Links -->
      <div>
        <h3 class="text-text font-bold mb-4">{footer.quick_links}</h3>
        <ul class="space-y-3">
          {quickLinks.map((link) => (
            <li>
              <a href={link.href} class="text-muted text-sm hover:text-accent transition-colors flex items-center gap-2 group">
                <span class="w-1.5 h-1.5 rounded-full bg-border group-hover:bg-accent transition-colors"></span>
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Column 3: Utility & Action -->
      <div>
        <h3 class="text-text font-bold mb-4">{footer.utility}</h3>
        <ul class="space-y-3 mb-6">
          <li>
            <a href="/privacy" class="text-muted text-sm hover:text-accent transition-colors">{footer.privacy}</a>
          </li>
          <li>
            <a href="/terms" class="text-muted text-sm hover:text-accent transition-colors">{footer.terms}</a>
          </li>
        </ul>
        
        <!-- vCard Download Button -->
        <a 
          href="/zeeshan_haider.vcf" 
          download="Zeeshan_Haider.vcf"
          class="inline-flex items-center gap-2 px-5 py-2.5 bg-accent/10 border border-accent/30 text-accent text-sm font-semibold rounded-lg hover:bg-accent hover:text-bg transition-all duration-300 group"
        >
          <svg class="w-4 h-4 group-hover:scale-110 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m0 0l-6-6m6 6l6-6M4 16h16"></path>
          </svg>
          {footer.contact_action}
        </a>
      </div>

    </div>

    <!-- Bottom Copyright Bar -->
    <div class="mt-12 pt-8 border-t border-border/50 flex flex-col md:flex-row items-center justify-between gap-4 text-xs text-muted">
      <p>{copyrightText}</p>
      <p class="flex items-center gap-1">
        Built with <span class="text-red-500 animate-pulse">❤</span> in Dubai, UAE
      </p>
    </div>
  </div>
</footer>