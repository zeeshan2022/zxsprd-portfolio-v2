---
import enData from '../data/en/data.json';
import arData from '../data/ar/data.json';
import zhData from '../data/zh/data.json';
import frData from '../data/fr/data.json';
import urData from '../data/ur/data.json';
import psData from '../data/ps/data.json';

const allLanguages = { en: enData, ar: arData, zh: zhData, fr: frData, ur: urData, ps: psData };
const currentLang = Astro.url.pathname.split('/')[1] || 'en';
const data = allLanguages[currentLang] || enData;

const { footer, hero } = data;
const currentYear = new Date().getFullYear();
// Replace {year} placeholder in copyright string
const copyrightText = footer.copyright.replace('{year}', currentYear.toString());

const quickLinks = [
  { label: 'Home', href: '/' },
  { label: 'Blog', href: '/blog/' },
  { label: 'Projects', href: '/projects/' },
  { label: 'Links', href: '/links/' },
];
