---
// 1. Import ALL language files
import enData from '../data/en/data.json';
import arData from '../data/ar/data.json';
import zhData from '../data/zh/data.json';
import frData from '../data/fr/data.json';
import urData from '../data/ur/data.json'
import psData from '../data/ps/data.json';

// 2. Create a map of all supported languages
const allLanguages = {
  en: enData,
  ar: arData,
  zh: zhData,
  fr: frData,
   ur: urData,
   ps: psData, 

};

// 3. Detect language from URL (e.g., '/ar/' becomes 'ar', '/zh/' becomes 'zh')
const currentLang = Astro.url.pathname.split('/')[1] || 'en';

// 4. Load the correct data, defaulting to English if the language isn't found
const data = allLanguages[currentLang] || enData;



  const { skills, sections } = data;
---

<section id="skills" class="py-20 px-6">
  <div class="max-w-6xl mx-auto">
    <h2 class="text-3xl font-bold mb-10 flex items-center gap-3">
      <span class="w-3 h-3 rounded-full bg-accent shadow-[0_0_10px_#00e0b8]"></span>
       {sections.skills}
    </h2>
    <div class="grid md:grid-cols-2 gap-6">
      {skills.map((skill) => (
        <div class="p-6 rounded-xl bg-card border border-border hover:border-accent/50 transition-all duration-300 hover:-translate-y-1">
          <h3 class="text-xl font-bold text-accent mb-3">{skill.category}</h3>
          <p class="text-muted leading-relaxed">{skill.items}</p>
        </div>
      ))}
    </div>
  </div>
</section>